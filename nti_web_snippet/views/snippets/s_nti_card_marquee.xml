                            <div class="nti_web_snippet__marquee__group nti_web_snippet__marquee__group--clone" aria-hidden="true"/>
                        </div>
                    </div>
                </div>
                
                <!-- Footer Action -->
                <div class="container text-center mt-5 mb-2 s_allow_columns">
                    <a href="#" class="btn rounded-pill border d-inline-flex align-items-center justify-content-center px-4 py-2 gap-2 text-dark bg-white shadow-sm" style="font-size: 0.95rem; font-weight: 500;">
                        Portofolio Lainnya <i class="fa fa-arrow-right text-muted"/>
                    </a>
                </div>
            </div>
        </section>
    </template>

</odoo>
