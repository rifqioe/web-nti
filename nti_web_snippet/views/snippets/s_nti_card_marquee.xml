<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="s_nti_card_marquee" name="NTI - Projects Marquee">
        <section class="s_nti_card_marquee pt96 pb96" data-snippet="s_nti_card_marquee" data-name="Projects Marquee">
            <div class="container-fluid overflow-hidden px-0">
                <!-- Header -->
                <div class="container text-center mb-5 s_allow_columns">
                    <div class="d-inline-flex align-items-center bg-dark text-white rounded-pill px-3 py-2 mb-3 shadow-sm">
                        <span class="small fw-semibold">Our Portfolio</span>
                    </div>
                    <h2 class="display-5 fw-bold text-primary mb-3">Explore Our Recent Projects</h2>
                    <p class="text-muted lead mx-auto" style="max-width: 650px;">
                        Discover the companies that have entrusted us with their challenges
                        and experienced successful resolutions through our tailored solutions.
                    </p>
                </div>
                
                <!-- Marquee Track -->
                <div class="nti_web_snippet__marquee nti_web_snippet__marquee--cards nti_web_snippet__marquee--pause-hover nti_web_snippet__marquee--fade" style="--nti-marquee-gap: 32px; --nti-marquee-duration: 40s;">
                    <div class="nti_web_snippet__marquee__viewport pb-3 pt-3">
                        <div class="nti_web_snippet__marquee__track">
                            <div class="nti_web_snippet__marquee__group nti_web_snippet__marquee__group--primary">
                                <!-- Card 1 -->
                                <div class="nti_web_snippet__marquee__item nti-card-item">
                                    <div class="card h-100 rounded-4 bg-white overflow-hidden text-decoration-none text-body" style="border: 1px solid #E5E7EB;">
                                        <div class="position-relative w-100">
                                            <div class="nti-card-thumbnail w-100 position-relative">
                                                <img src="/web/image/website.s_reference_demo_image_1" class="img-fluid w-100 object-fit-cover" alt="Clever SaaS"/>
                                            </div>
                                        </div>
                                        <div class="card-body d-flex flex-column gap-3 p-4 pt-1">
                                            <div class="d-flex align-items-start justify-content-between gap-3">
                                                <h4 class="card-title fw-semibold mb-0 text-dark fs-5">Clever — Saas Landing Page</h4>
                                                <span class="badge text-muted bg-light rounded-pill border fw-normal flex-shrink-0 px-3 py-2">Agency</span>
                                            </div>
                                            <p class="card-text text-muted mb-4 lh-lg flex-grow-1" style="font-size: 0.95rem;">
                                                Clever is a modern SaaS landing page template designed to showcase your software features effortlessly. With...
                                            </p>
                                            <a href="#" class="btn btn-light bg-light rounded-pill border d-inline-flex align-items-center me-auto fw-semibold px-4 py-2 gap-2 mt-auto" style="font-size: 0.9rem;">
                                                Read Full <i class="fa fa-arrow-right small text-muted"/>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <!-- Card 2 -->
                                <div class="nti_web_snippet__marquee__item nti-card-item">
                                    <div class="card h-100 rounded-4 bg-white overflow-hidden text-decoration-none text-body" style="border: 1px solid #E5E7EB;">
                                        <div class="position-relative w-100">
                                            <div class="nti-card-thumbnail w-100 position-relative">
                                                <img src="/web/image/website.s_reference_demo_image_2" class="img-fluid w-100 object-fit-cover" alt="Telkomsel Dashboard"/>
                                            </div>
                                        </div>
                                        <div class="card-body d-flex flex-column gap-3 p-4 pt-1">
                                            <div class="d-flex align-items-start justify-content-between gap-3">
                                                <h4 class="card-title fw-semibold mb-0 text-dark fs-5">Telkomsel-Benchmark Solution</h4>
                                                <span class="badge text-muted bg-light rounded-pill border fw-normal flex-shrink-0 px-3 py-2">Dashboard</span>
                                            </div>
                                            <p class="card-text text-muted mb-4 lh-lg flex-grow-1" style="font-size: 0.95rem;">
                                                Genius is a minimal SaaS landing page template, designed to be modern, simple, and easily adaptable to any brand.
                                            </p>
                                            <a href="#" class="btn btn-light bg-light rounded-pill border d-inline-flex align-items-center me-auto fw-semibold px-4 py-2 gap-2 mt-auto" style="font-size: 0.9rem;">
                                                Read Full <i class="fa fa-arrow-right small text-muted"/>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <!-- Card 3 -->
                                <div class="nti_web_snippet__marquee__item nti-card-item">
                                    <div class="card h-100 rounded-4 bg-white overflow-hidden text-decoration-none text-body" style="border: 1px solid #E5E7EB;">
                                        <div class="position-relative w-100">
                                            <div class="nti-card-thumbnail w-100 position-relative">
                                                <img src="/web/image/website.s_reference_demo_image_3" class="img-fluid w-100 object-fit-cover" alt="Telkomsel FBB"/>
                                            </div>
                                        </div>
                                        <div class="card-body d-flex flex-column gap-3 p-4 pt-1">
                                            <div class="d-flex align-items-start justify-content-between gap-3">
                                                <h4 class="card-title fw-semibold mb-0 text-dark fs-5">Telkomsel — FBB</h4>
                                                <span class="badge text-muted bg-light rounded-pill border fw-normal flex-shrink-0 px-3 py-2">Dashboard</span>
                                            </div>
                                            <p class="card-text text-muted mb-4 lh-lg flex-grow-1" style="font-size: 0.95rem;">
                                                The ideal template for crafting a sleek and efficient waitlist landing page.
                                            </p>
                                            <a href="#" class="btn btn-light bg-light rounded-pill border d-inline-flex align-items-center me-auto fw-semibold px-4 py-2 gap-2 mt-auto" style="font-size: 0.9rem;">
                                                Read Full <i class="fa fa-arrow-right small text-muted"/>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <!-- Card 4 -->
                                <div class="nti_web_snippet__marquee__item nti-card-item">
                                    <div class="card h-100 rounded-4 bg-white overflow-hidden text-decoration-none text-body" style="border: 1px solid #E5E7EB;">
                                        <div class="position-relative w-100">
                                            <div class="nti-card-thumbnail w-100 position-relative">
                                                <img src="/web/image/website.s_reference_demo_image_4" class="img-fluid w-100 object-fit-cover" alt="HSE Just Click"/>
                                            </div>
                                        </div>
                                        <div class="card-body d-flex flex-column gap-3 p-4 pt-1">
                                            <div class="d-flex align-items-start justify-content-between gap-3">
                                                <h4 class="card-title fw-semibold mb-0 text-dark fs-5">HSE- Just Click</h4>
                                                <span class="badge text-muted bg-light rounded-pill border fw-normal flex-shrink-0 px-3 py-2">Dashboard</span>
                                            </div>
                                            <p class="card-text text-muted mb-4 lh-lg flex-grow-1" style="font-size: 0.95rem;">
                                                The ideal template for crafting a sleek and efficient waitlist landing page.
                                            </p>
                                            <a href="#" class="btn btn-light bg-light rounded-pill border d-inline-flex align-items-center me-auto fw-semibold px-4 py-2 gap-2 mt-auto" style="font-size: 0.9rem;">
                                                Read Full <i class="fa fa-arrow-right small text-muted"/>
                                            </a>
                                        </div>
                                    </div>
                                </div>
